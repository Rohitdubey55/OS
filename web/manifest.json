{
  "id": "com.personal.os",
  "name": "PersonalOS",
  "short_name": "PersonalOS",
  "description": "Your Personal Operating System — tasks, habits, diary, finance, vision, all in one.",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "background_color": "#0B0E14",
  "theme_color": "#4F46E5",
  "orientation": "any",
  "lang": "en",
  "dir": "ltr",
  "categories": ["productivity", "lifestyle", "utilities"],
  "prefer_related_applications": false,
  "launch_handler": { "client_mode": "focus-existing" },
  "icons": [
    { "src": "icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
  ],

  "shortcuts": [
    {
      "name": "Add Task",
      "short_name": "Task",
      "description": "Quick add a new task",
      "url": "./index.html?action=add&view=tasks#tasks",
      "icons": [{ "src": "icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "New Diary Entry",
      "short_name": "Diary",
      "description": "Write today's diary entry",
      "url": "./index.html?action=add&view=diary#diary",
      "icons": [{ "src": "icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Start Pomodoro",
      "short_name": "Pomodoro",
      "description": "Start a focus session",
      "url": "./index.html?action=start&view=pomodoro#pomodoro",
      "icons": [{ "src": "icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Check Habits",
      "short_name": "Habits",
      "description": "Check off today's habits",
      "url": "./index.html#habits",
      "icons": [{ "src": "icon-192.png", "sizes": "192x192" }]
    }
  ],

  "share_target": {
    "action": "./index.html",
    "method": "GET",
    "params": {
      "title": "share_title",
      "text": "share_text",
      "url": "share_url"
    }
  },

  "protocol_handlers": [
    {
      "protocol": "web+personalos",
      "url": "./index.html?deeplink=%s"
    }
  ]
}
