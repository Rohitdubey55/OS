<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/budget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="18dp">

    <!-- Header: THIS WEEK label + percent pill -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="THIS WEEK"
            android:textColor="#A5B4FC"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/budget_pct"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/widget_pill_accent"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:textColor="#C4B5FD"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Main amount: big + secondary -->
    <TextView
        android:id="@+id/budget_amount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#F9FAFB"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginTop="10dp"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/budget_caption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#9CA3AF"
        android:textSize="12sp"
        android:layout_marginTop="2dp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="12dp" />

    <!-- Chunky rounded progress bar -->
    <ProgressBar
        android:id="@+id/budget_bar"
        style="@android:style/Widget.Material.Light.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:max="100"
        android:progress="0"
        android:progressDrawable="@drawable/widget_progress_green" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/budget_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="14dp"
        android:visibility="gone">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No budget set"
            android:textColor="#E4E7EC"
            android:textSize="14sp"
            android:textStyle="bold" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configure a weekly budget in Settings"
            android:textColor="#6B7280"
            android:textSize="11sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

</LinearLayout>
