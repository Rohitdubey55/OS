<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="18dp">

    <!-- Header row: TODAY label + count pill -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TODAY"
                android:textColor="#A5B4FC"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#F9FAFB"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_count_pill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/widget_pill_accent"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:textColor="#C4B5FD"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="14dp" />

    <!-- 3 task rows -->
    <LinearLayout
        android:id="@+id/task_1_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="9dp"
        android:paddingBottom="9dp">

        <FrameLayout
            android:id="@+id/task_1_dot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/widget_dot_p3" />

        <TextView
            android:id="@+id/task_1_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E4E7EC"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/task_2_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="9dp"
        android:paddingBottom="9dp">

        <FrameLayout
            android:id="@+id/task_2_dot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/widget_dot_p3" />

        <TextView
            android:id="@+id/task_2_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E4E7EC"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/task_3_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="9dp"
        android:paddingBottom="9dp">

        <FrameLayout
            android:id="@+id/task_3_dot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/widget_dot_p3" />

        <TextView
            android:id="@+id/task_3_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E4E7EC"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/widget_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="18dp"
        android:paddingBottom="18dp"
        android:visibility="gone">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All clear"
            android:textColor="#E4E7EC"
            android:textSize="17sp"
            android:textStyle="bold" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No tasks for today"
            android:textColor="#6B7280"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Footer "more" pill -->
    <TextView
        android:id="@+id/widget_footer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_gravity="end"
        android:background="@drawable/widget_pill_accent"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:textColor="#C4B5FD"
        android:textSize="11sp"
        android:textStyle="bold"
        android:visibility="gone" />

</LinearLayout>
