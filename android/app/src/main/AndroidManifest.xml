<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:networkSecurityConfig="@xml/network_security_config"
        android:enableOnBackInvokedCallback="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <!-- App launcher -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep links: personalos://tasks, personalos://habits, etc.
                 Picked up by the appUrlOpen listener in main.js. -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="personalos" />
            </intent-filter>

            <!-- Share target: receive plain text from other apps (e.g. notes, tasks).
                 The web side reads window.shareIntent / appUrlOpen to consume it. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>

            <!-- App Shortcuts: surfaced on long-press of the launcher icon. -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>

        <!-- ============================================================
             Home-screen widgets
             ============================================================ -->

        <!-- Today's Tasks widget receiver -->
        <receiver
            android:name="com.personal.os.widgets.TodaysTasksWidget"
            android:label="@string/widget_todays_tasks_label"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_todays_tasks_info" />
        </receiver>

        <!-- Habit Checklist widget receiver -->
        <receiver
            android:name="com.personal.os.widgets.HabitChecklistWidget"
            android:label="@string/widget_habit_checklist_label"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_habit_checklist_info" />
        </receiver>

        <!-- Weekly Budget widget receiver -->
        <receiver
            android:name="com.personal.os.widgets.WeeklyBudgetWidget"
            android:label="@string/widget_weekly_budget_label"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_weekly_budget_info" />
        </receiver>

        <!-- Life Progress widget receiver -->
        <receiver
            android:name="com.personal.os.widgets.LifeProgressWidget"
            android:label="@string/widget_life_progress_label"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_life_progress_info" />
        </receiver>

    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Notifications (required for Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Vibration for notification alerts -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Wake lock so notification delivery works reliably -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Reschedule local notifications after device reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Exact alarms for habit/reminder scheduling (Android 12+) -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <!-- USE_EXACT_ALARM is a non-user-revokable alternative available on Android 13+ -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

</manifest>
